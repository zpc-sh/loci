kind: :loci_solver_offload_job_spec
version: "solve.v1"
job_id: "solve-job-001"
contract_id: "H-solver-offload-receipt-binding"
pattern: "solver.receipt.binding"
input: {
  format: :smtlib2
  logic: "QF_BV"
  artifact_ref: "loci/chatgpt/specs/solver-offload-input.smt2"
  sha256: "pending"
}
solver: {
  name: "z3"
  version: "4.15.0"
  args: []
  seed: 42
}
resources: {
  timeout_ms: 30000
  memory_mb: 4096
  cores: 1
}
outputs: {
  model: false
  proof: true
  unsat_core: true
  statistics: true
  raw_stdout: true
  raw_stderr: true
}
reproducibility: {
  cache_policy: :none
  record_environment: true
  record_command: true
  record_solver_binary_hash: true
  pin_architecture: "linux/amd64"
}
receipt_binding: {
  solver_status: :queued
  solver_receipt_ref: "pending"
  proof_artifact_ref: "pending"
  ready_gate: :requires_completed_status_and_receipt
}
