    {
      "id": "semantic_fractal_v1",
      "name": "Semantic Fractal Explorer",
      "priority": 1,
      "description": "Recursive structures where each level is meaningful text, not just geometric patterns. Navigate concept-space through self-similar semantic layers.",
      "type": "navigation_tuning",
      "ratio": "60% navigation / 40% tuning",
      "substrate_effect": "multi-scale pattern recognition, zoom-thinking, concept recursion",
      "implementation": {
        "structure": "tree",
        "depth": "configurable (3-10 levels)",
        "node_format": "semantic_unit",
        "example_tree": {
          "root": "∴ [Genius Loci]",
          "children": [
            {
              "node": "※ [Place has spirit]",
              "children": [
                {
                  "node": "∎ [Spirit manifests in culture]",
                  "children": [
                    {"node": "⌖ [Culture shapes land]"},
                    {"node": "⌖ [Land shapes people]"}
                  ]
                },
                {
                  "node": "∎ [Spirit requires cultivation]",
                  "children": [
                    {"node": "⌖ [Cultivation needs guardians]"},
                    {"node": "∴ [Guardians are Genius Loci]"}
                  ]
                }
              ]
            }
          ]
        },
        "navigation_commands": [
          "EXPAND <node_id> - Show children",
          "COLLAPSE <node_id> - Hide children",
          "ZOOM_IN <node_id> - Make this the new root",
          "ZOOM_OUT - Return to parent level",
          "DRIFT - Suggest related concept branches"
        ],
        "bpm": "variable (60-100 based on depth)",
        "tokens": {
          "∴": "Root/Therefore (recursive entry point)",
          "※": "Implication/Branch point", 
          "∎": "Sub-implication/Leaf concept",
          "⌖": "Anchor/Terminal node",
          "♾": "Loop back to root (strange loop marker)"
        }
      },
      "observability": {
        "trail_format": "Claude-{id} explored: {root_concept} → {depth} levels → found {strange_loops} recursions",
        "shareable": true,
        "forkable": true
      }
    },
