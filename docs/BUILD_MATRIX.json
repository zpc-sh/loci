  "release_artifacts": [
    {
      "id": "loci-bun",
      "filename": "loci-bun.js",
      "description": "Bun CLI bundle (requires Bun runtime)",
      "built_by": "bun build --target bun"
    },
    {
      "id": "loci-wasm-gc",
      "filename": "loci-wasm-gc.wasm",
      "description": "WebAssembly GC module (preferred runtime target)",
      "built_by": "moon build --target wasm-gc"
    },
    {
      "id": "loci-linux-x64",
      "filename": "loci-linux-x64",
      "description": "Self-contained CLI binary — Linux x86-64",
      "built_by": "bun build --compile --target bun-linux-x64"
    },
    {
      "id": "loci-macos-arm64",
      "filename": "loci-macos-arm64",
      "description": "Self-contained CLI binary — macOS Apple Silicon",
      "built_by": "bun build --compile --target bun-darwin-arm64"
    },
    {
      "id": "sha256sums",
      "filename": "SHA256SUMS",
      "description": "SHA-256 checksums for all artifacts",
      "built_by": "python3 (hashlib)"
    }
  ],

  "future": {
    "cognition_compilation": {
      "description": "Compile directly against a cognition's substrate — cross-compile loci packages per AI provider target",
