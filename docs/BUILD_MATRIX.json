      "status": "experimental"
    }
  ],

  "release_platforms": [
    {
      "id": "linux-x64",
      "label": "Linux x86-64",
      "runner": "ubuntu-latest",
      "bun_target": "bun-linux-x64",
      "artifact": "loci-linux-x64"
    },
    {
      "id": "macos-arm64",
      "label": "macOS Apple Silicon",
      "runner": "macos-latest",
      "bun_target": "bun-darwin-arm64",
