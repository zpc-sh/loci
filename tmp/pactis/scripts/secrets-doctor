#!/usr/bin/env bash
set -euo pipefail

dir=${1:-${SECRETSDIR:-}}
project=${PROJECT:-pactis}

echo "[secrets-doctor] Project: $project"

if [ -z "$dir" ]; then
  if [ -L "$HOME/.sshs/$project" ]; then
    dir=$(readlink "$HOME/.sshs/$project")
  fi
fi

if [ -z "$dir" ]; then
  echo "[secrets-doctor] No SECRETSDIR and no ~/.sshs/$project symlink."
  exit 2
fi

echo "[secrets-doctor] Using dir: $dir"

if [ ! -d "$dir" ]; then
  echo "[secrets-doctor] Directory does not exist"; exit 2
fi

perm=$(stat -f %Mp%Lp "$dir" 2>/dev/null || stat -c %a "$dir")
if [ "$perm" != "700" ]; then
  echo "[secrets-doctor] WARN: directory perms should be 0700 (got $perm)"
else
  echo "[secrets-doctor] OK: directory perms 0700"
fi

os=$(uname -s)
if [ "$os" = "Darwin" ]; then
  case "$dir" in
    *.noindex) echo "[secrets-doctor] OK: .noindex suffix on macOS";;
    *) echo "[secrets-doctor] WARN: recommend .noindex suffix on macOS";;
  esac
fi

status=0
for f in openai_api_key anthropic_api_key xai_api_key gemini_api_key mistral_api_key ai21_api_key; do
  path="$dir/$f"
  if [ -f "$path" ]; then
    pperm=$(stat -f %Mp%Lp "$path" 2>/dev/null || stat -c %a "$path")
    if [ "$pperm" != "600" ]; then
      echo "[secrets-doctor] WARN: $f perms should be 0600 (got $pperm)"; status=1
    else
      echo "[secrets-doctor] OK: $f present with 0600 perms"
    fi
  fi
done

exit $status

