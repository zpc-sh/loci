#!/usr/bin/env bash
set -euo pipefail

# Harden defaults
umask 077

PROJECT="${PROJECT:-pactis}"
ENC_DIR="${ENC_DIR:-secrets.enc}"
SIZE_MB="${SIZE_MB:-16}"
USE_RAMDISK="${USE_RAMDISK:-1}"

info() { printf "[secrets-shell] %s\n" "$*"; }
die() { printf "[secrets-shell] ERROR: %s\n" "$*" >&2; exit 1; }

if [ ! -d "$ENC_DIR" ]; then
  die "Encrypted dir not found: $ENC_DIR"
fi

if ! command -v age >/dev/null 2>&1 || ! command -v age-plugin-ssh >/dev/null 2>&1; then
  die "Install age and age-plugin-ssh (brew install age age-plugin-ssh)"
fi

if ! ssh-add -L >/dev/null 2>&1; then
  die "No ssh-agent keys available. Ensure Secretive or ssh-agent is configured."
fi

OS_NAME=$(uname -s)

cleanup() {
  if [ "${_MOUNT_METHOD:-tmpdir}" = "ramdisk" ]; then
    if [ "$OS_NAME" = "Darwin" ]; then
      hdiutil detach "${_DEV}" -force >/dev/null 2>&1 || true
    elif [ "$OS_NAME" = "Linux" ]; then
      sudo umount "$MOUNT_DIR" >/dev/null 2>&1 || true
      rmdir "$MOUNT_DIR" 2>/dev/null || true
    fi
  else
    rm -rf "$MOUNT_DIR" 2>/dev/null || true
  fi
  [ -L "$HOME/.sshs/$PROJECT" ] && rm -f "$HOME/.sshs/$PROJECT"
}
trap cleanup EXIT INT TERM

mkdir -p "$HOME/.sshs"
chmod 700 "$HOME/.sshs"

if [ "$USE_RAMDISK" = "1" ]; then
  if [ "$OS_NAME" = "Darwin" ]; then
    # macOS RAM disk
    SECTORS=$((SIZE_MB * 2048))
    _DEV=$(hdiutil attach -nomount "ram://$SECTORS")
    diskutil erasevolume APFS "Secrets-$PROJECT.noindex" "$_DEV" >/dev/null
    MOUNT_DIR="/Volumes/Secrets-$PROJECT.noindex"
    _MOUNT_METHOD=ramdisk
    # Disable Spotlight indexing best-effort
    command -v mdutil >/dev/null && mdutil -i off "$MOUNT_DIR" >/dev/null 2>&1 || true
  elif [ "$OS_NAME" = "Linux" ]; then
    # Linux tmpfs
    MOUNT_DIR="/run/user/${UID}/sshs-$PROJECT"
    mkdir -p "$MOUNT_DIR"
    chmod 700 "$MOUNT_DIR"
    sudo mount -t tmpfs -o size=${SIZE_MB}m,mode=0700 tmpfs "$MOUNT_DIR"
    _MOUNT_METHOD=ramdisk
  else
    MOUNT_DIR="$(mktemp -d)"
    _MOUNT_METHOD=tmpdir
  fi
else
  MOUNT_DIR="$(mktemp -d)"
  _MOUNT_METHOD=tmpdir
fi

chmod 700 "$MOUNT_DIR"

# Decrypt all *.age
shopt -s nullglob
for enc in "$ENC_DIR"/*.age; do
  name="$(basename "$enc" .age)"
  age -d "$enc" > "$MOUNT_DIR/$name"
  chmod 600 "$MOUNT_DIR/$name"
done

export SECRETSDIR="$MOUNT_DIR"

ln -sfn "$MOUNT_DIR" "$HOME/.sshs/$PROJECT"

info "Mounted secrets at: $SECRETSDIR"
info "Symlink: $HOME/.sshs/$PROJECT"
info "Files: $(ls -1 "$SECRETSDIR" 2>/dev/null | xargs echo || true)"
info "Starting login shell. Exit to tear down."
exec "${SHELL:-/bin/bash}" -l

